# Copy to .env and fill in. Never commit .env.

# --- LLM API keys (two-model ensemble) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional free-tier fallback (if you switch providers later)
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- Model names ---
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# --- Confidence thresholds (tune on eval set) ---
CONFIDENCE_HIGH=0.8
CONFIDENCE_LOW=0.5

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Privacy ---
# Salt used to hash phone numbers in logs/storage
PHONE_HASH_SALT=change-me

# --- Storage ---
DB_PATH=data/app.db
